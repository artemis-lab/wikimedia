{
  "name": "wikimedia",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "artemis-lab",
  "license": "MIT",
  "description": "A React web application that surfaces Wikipedia's On This Day events using the Wikimedia Feed API",
  "repository": {
    "type": "git",
    "url": "https://github.com/artemis-lab/wikimedia.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "ci": "npm run format:check && npm run lint && npm run type-check && npm run type-check:test && npm run test && npm run build",
    "clean": "rm -rf dist",
    "dev": "vite",
    "format": "prettier --write \"**/*.{js,ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:components": "vitest run test/components",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "vitest run --coverage && open coverage/index.html",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run test/unit",
    "test:watch": "vitest",
    "type-check": "tsc --project tsconfig.app.json --noEmit",
    "type-check:test": "tsc --project tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@mantine/core": "8.3.15",
    "@mantine/dates": "8.3.15",
    "@mantine/hooks": "8.3.15",
    "@reduxjs/toolkit": "2.11.2",
    "@tabler/icons-react": "3.37.1",
    "dayjs": "1.11.19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "9.2.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.16",
    "@vitest/ui": "4.0.16",
    "eslint": "9.39.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "msw": "2.10.5",
    "postcss": "8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "7.0.1",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.0",
    "uuid": "11.1.0",
    "vite": "7.3.0",
    "vitest": "4.0.16"
  }
}
